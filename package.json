{
  "name": "cadence",
  "version": "0.1.0",
  "private": true,
  "description": "Attune — a voice-first AI mock interview platform. LangGraph is the mind; ElevenLabs is the voice.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "predev": "pnpm --filter @cadence/types build",
    "dev": "pnpm --parallel --stream -r dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @cadence/api build",
    "start:api": "pnpm --filter @cadence/api start:prod",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @cadence/api db:generate",
    "db:migrate": "pnpm --filter @cadence/api db:migrate",
    "db:seed": "pnpm --filter @cadence/api db:seed",
    "db:studio": "pnpm --filter @cadence/api db:studio"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
