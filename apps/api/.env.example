NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Postgres — Neon in prod, local in dev.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cadence?schema=public

# Auth secrets (used from M1). Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars-long

# AI provider (M3). Provider-agnostic — swap without touching app code.
# groq (default, functional) | gemini (placeholder) | openai (placeholder) | mock (offline/dev+tests)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
