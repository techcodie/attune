# ─────────────────────────────────────────────────────────────
# Cadence — root env reference.
# Copy the relevant blocks into apps/api/.env and apps/web/.env.
# Nothing secret lives here; this file is committed as documentation.
# ─────────────────────────────────────────────────────────────

# ── apps/api ────────────────────────────────────────────────
# Server
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed browser origins.
CORS_ORIGIN=http://localhost:5173

# Database (Neon in prod, local Postgres in dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cadence?schema=public

# Auth (added in M1) — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# AI (added in M3)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Voice (added in M4)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# ── apps/web ────────────────────────────────────────────────
# Vite only exposes vars prefixed with VITE_ to the browser.
VITE_API_URL=http://localhost:4000
